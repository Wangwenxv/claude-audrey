<Application x:Class="Audrey.Chat.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="Application_Startup">
  <Application.Resources>
    <SolidColorBrush x:Key="AudreyBg" Color="#F8F6F0" />
    <SolidColorBrush x:Key="AudreyPanel" Color="#FFFDF8" />
    <SolidColorBrush x:Key="AudreyAccent" Color="#CFAF5F" />
    <SolidColorBrush x:Key="AudreyText" Color="#253A3D" />
    <SolidColorBrush x:Key="AudreyMuted" Color="#6D8184" />
  </Application.Resources>
</Application>
